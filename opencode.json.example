{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimi (Moonshot)",
      "options": {
        "baseURL": "https://api.moonshot.ai/v1",
        "apiKey": "{env:MOONSHOT_API_KEY}"
      },
      "models": {
        "kimi-k3": { "name": "Kimi K3" },
        "kimi-k2.7-code": { "name": "Kimi K2.7 Code" }
      }
    },
    "openai": {
      "npm": "@ai-sdk/openai",
      "options": { "apiKey": "{env:OPENAI_API_KEY}" },
      "models": {
        "gpt-5.6": { "name": "GPT-5.6" }
      }
    }
  },

  "mcp": {
    "pdf-reader": {
      "type": "local",
      "command": ["/opt/homebrew/bin/pdf-reader-mcp"]
    },
    "excel": {
      "type": "local",
      "command": ["excel-mcp-server"]
    },
    "tavily-remote": {
      "type": "local",
      "command": [
        "npx", "-y", "mcp-remote",
        "https://mcp.tavily.com/mcp/?tavilyApiKey=<YOUR_TAVILY_API_KEY>"
      ]
    },
    "mcp-atlassian": {
      "type": "local",
      "command": ["/opt/homebrew/bin/uvx", "mcp-atlassian"],
      "environment": {
        "CONFLUENCE_URL": "https://<your-domain>.atlassian.net",
        "CONFLUENCE_USERNAME": "<your-email>",
        "CONFLUENCE_PERSONAL_TOKEN": "<YOUR_CONFLUENCE_TOKEN>",
        "JIRA_URL": "https://<your-domain>.atlassian.net/",
        "JIRA_PERSONAL_TOKEN": "<YOUR_JIRA_TOKEN>"
      }
    },
    "beads": {
      "type": "local",
      "command": ["beads-mcp"]
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "huggingface": {
      "type": "remote",
      "url": "https://hf.co/mcp"
    },
    "ss-gateway": {
      "type": "local",
      "command": [
        "node",
        "<path-to-ss-ai-setup>/mcp-launcher/mcp-wrapper.js",
        "<YOUR_SS_GATEWAY_UUID>"
      ]
    },
    "docx-mcp": {
      "type": "local",
      "command": ["/opt/homebrew/bin/uvx", "docx-mcp"]
    }
  },

  "permission": {
    "bash":      "allow",
    "read":      "allow",
    "edit":      "allow",
    "webfetch":  "allow",
    "websearch": "allow"
  }
}
