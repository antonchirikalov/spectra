# ─────────────────────────────────────────────────────────────────────────────
# spectra — единая маршрутизация моделей / single model-routing config
#
# Приоритет (от высшего к низшему):
#   requirements_runner:      plan/params.yaml (в папке прогона) → CLI --model → этот файл
#   solution_design_runner:   CLI --models → этот файл
# Формат модели: provider/model-id (провайдеры задаются в .opencode/opencode.json,
# ключи — в .env). Доступные из коробки: kimi/kimi-k3, kimi/kimi-k2.7-code, openai/gpt-5.5
# ─────────────────────────────────────────────────────────────────────────────

# Дефолт для всех агентов, если нет более точечного оверрайда
default_model: kimi/kimi-k3

# Per-agent overrides для requirements_runner (extract + discovery).
# Раскомментируйте нужные строки, чтобы закрепить модель за агентом
# (закреплённый агент игнорирует CLI --model и default_model):
agents: {}
# agents:
#   source_processor: kimi/kimi-k3       # извлечение фактов из источников
#   requirements_writer: kimi/kimi-k3    # сборка _requirements.md
#   requirements_critic: openai/gpt-5.5  # критик на другой модели — не самопроверяется
#   arch_probe: kimi/kimi-k3             # discovery: генерация вопросов
#   arch_critic: openai/gpt-5.5          # discovery: discovery_report.md

# Solution design pipeline
solution_design:
  # Модели-кандидаты Фазы 1: каждая строка = один кандидат, все параллельно.
  # Одна строка — один дизайн без конкурса; две+ — selector выберет лучший.
  designer_models:
    - kimi/kimi-k3
    # - openai/gpt-5.5
  selector_model: kimi/kimi-k3   # выбирает лучшего кандидата (когда их >1)
  critic_model: kimi/kimi-k3     # критик дизайна; revision всегда идёт на winning_model
