# Copy this file to .env and fill in your values
# cp .env.example .env
# At least one AI provider key is required.

# ── AI Providers ───────────────────────────────────────────────────────────────

# Kimi K3 (Moonshot AI) — recommended default, best agentic benchmark
# Get key: https://platform.moonshot.ai
MOONSHOT_API_KEY=sk-...

# OpenAI — GPT-5.5
# Get key: https://platform.openai.com
OPENAI_API_KEY=sk-...

# DeepSeek — cheapest tier for high-volume extraction
# Get key: https://platform.deepseek.com  (5M free tokens on signup)
# DEEPSEEK_API_KEY=sk-...

# Qwen (Alibaba) — 1M context, good for massive doc sets
# Get key: https://dashscope.aliyuncs.com
# QWEN_API_KEY=...

# Anthropic Claude — quality hedge on writer/critic agents
# Get key: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Fireworks — US-hosted mirror of open weights (Kimi, DeepSeek, Qwen)
# Use instead of direct provider for data residency compliance
# Get key: https://fireworks.ai
# FIREWORKS_API_KEY=...

# ── Integrations (optional) ────────────────────────────────────────────────────

# Confluence + Jira (mcp-atlassian)
CONFLUENCE_TOKEN=...
JIRA_TOKEN=...

# Tavily web search — embedded in opencode.json URL, not needed separately
# TAVILY_API_KEY=...
